{
    "name": "stephen2304/shopper-wishlist",
    "description": "Customer wishlist add-on for the Shopper e-commerce admin panel",
    "keywords": [
        "laravel",
        "shopper",
        "e-commerce",
        "wishlist",
        "addon"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "stephen2304"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "shopper/framework": "^3.0@beta",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "larastan/larastan": "^3.8",
        "laravel/pint": "^1.16",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Stephen2304\\ShopperWishlist\\": "src/",
            "Stephen2304\\ShopperWishlist\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stephen2304\\ShopperWishlist\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Stephen2304\\ShopperWishlist\\ShopperWishlistServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "analyse": "phpstan analyse",
        "format": "pint",
        "rector": "rector process --dry-run"
    }
}
