includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6

    paths:
        - src

    ignoreErrors:
        -
            message: '#Access to an undefined property (Illuminate\\Database\\Eloquent\\Model&)?Shopper\\([a-zA-Z]+\\)?Models\\Contracts\\[a-zA-Z]+::\$[a-zA-Z_]+#'
            identifier: property.notFound

    reportUnmatchedIgnoredErrors: false
